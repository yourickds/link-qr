# ===================================
# Docker Compose Project Configuration
# ===================================

# Project name prefix for containers, networks, and volumes.
# By default, uses the parent directory name.
# Uncomment and customize to override:
# COMPOSE_PROJECT_NAME=


# ===================================
# MySQL Database Configuration
# ===================================

# MySQL root user password
DB_ROOT_PASSWORD=root_password

# Database name to be created on first startup
DB_DATABASE=database

# MySQL regular user credentials
DB_USERNAME=user
DB_PASSWORD=password
